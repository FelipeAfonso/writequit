{
	"name": "writequit-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev:web": "bun run --filter @writequit/web dev",
		"dev:desktop": "bun run --filter @writequit/desktop dev",
		"build:ui": "bun run --filter @writequit/ui build",
		"build:web": "bun run --filter @writequit/ui build && bun run --filter @writequit/web build",
		"build:desktop": "bun run --filter @writequit/ui build && bun run --filter @writequit/desktop build",
		"check": "bun run --filter '*' check",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1"
	}
}
